# Phase-0 read API (Galaxy). Until library.booksgiant.com DNS is live you can point
# this at the school host, which serves the same routes:
#   https://school.booksgiant.com/api/bookstube
BOOKSTUBE_API_BASE=https://library.booksgiant.com/api/bookstube

# Public site URL — used for canonical / OG / sitemap absolute URLs.
NEXT_PUBLIC_SITE_URL=https://bookstube.ai

# GA4 for the library funnel. Defaults to G-71PTEX1YZF in code if unset; override here.
NEXT_PUBLIC_GA_ID=G-71PTEX1YZF
